# === Environment variables ===
# Refuse all .env-style files by default; whitelist only example/template.
.env
.env.*
*.env
!.env.example
!.env.template

# === Node.js / build ===
node_modules/
dist/
build/
coverage/
*.lcov
*.tgz
*.tar.gz
.npm
.eslintcache
.node_repl_history
.yarn-integrity

# === Next.js / dashboard ===
.next/
dashboard/.next/
.nuxt/
.vuepress/dist/
.serverless/
.fusebox/
.dynamodb/
.tern-port
.parcel-cache/
.cache/

# === Test / Jest caches ===
.jest-cache/
.jest-cache-*/
.nyc_output/

# === Python virtualenvs & caches ===
.venv/
venv/
ENV/
env/
env.bak/
venv.bak/
__pycache__/
*.py[cod]
*$py.class
.Python
.pytest_cache/
.mypy_cache/
.ruff_cache/
prism.egg-info/
*.egg-info/
*.egg
.eggs/
.installed.cfg
.coverage
htmlcov/

# === Logs & runtime ===
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pids
*.pid
*.seed
*.pid.lock

# === Reports (test outputs / mutation / junit) ===
# Note: tracked docs under docs/reports/ are NOT affected by this rule
# because Git only ignores untracked files matching this pattern.
reports/junit/
reports/mutation/
reports/coverage/

# === PRISM runtime artifacts (initialized from .sample files) ===
data/server-memory.json
test_orchestration_journal/checkpoint.json
test_journal/checkpoint.json
.prism-state.json
prismCoreStressResults.json
prismCoreAdvancedStressResults.json
prismCoreExtendedStressResults.json
# Also cover nested copies of the same regenerable stress-test artifacts
# (e.g. legacy_tests/tests_old/stress/results/*).
**/prismCoreStressResults.json
**/prismCoreAdvancedStressResults.json
**/prismCoreExtendedStressResults.json
simulation/out/

# === Test temporary artifacts ===
test-trustcontext-temp/
test-audit-temp-*/

# === Security: never commit private keys ===
*.pem
*.key
*.cert
*.pfx
*.p12
*.asc
keys/private/
keys/secret/

