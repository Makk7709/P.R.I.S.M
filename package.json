{
  "name": "prism",
  "version": "2.0.0",
  "description": "PRISM v2 - Advanced AI Orchestration System",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "test": "vitest run --config vitest.config.core-only.js",
    "test:watch": "vitest --config vitest.config.core-only.js",
    "test:core": "vitest run --config vitest.config.core.js",
    "test:core:watch": "vitest --config vitest.config.core.js",
    "coverage": "vitest run --coverage",
    "lint": "eslint . --ext .js,.ts,.mjs",
    "lint:fix": "eslint . --ext .js,.ts,.mjs --fix",
    "format": "prettier --write \"**/*.{js,ts,mjs,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,ts,mjs,json,md}\"",
    "typecheck": "tsc --noEmit",
    "prepare": "husky install || true",
    "test:consensus": "vitest run --config vitest.config.consensus.mjs",
    "demo:consensus": "node demo-consensus-live.js",
    "scenarios:all": "node run-consensus-tests.js",
    "coverage:consensus": "vitest run --config vitest.config.consensus.mjs && (command -v open >/dev/null 2>&1 && open coverage/index.html || true)",
    "test:phase1": "NODE_ENV=test jest __tests__/backend/services/ --coverage --verbose",
    "test:phase2": "NODE_ENV=test npm run test:enterprise:all",
    "test:enterprise:all": "NODE_ENV=test jest __tests__/backend/api/enterpriseExport.test.js __tests__/backend/middleware/ --coverage --verbose",
    "test:enterprise:middleware": "NODE_ENV=test jest __tests__/backend/middleware/ --coverage --verbose",
    "test:enterprise:api": "NODE_ENV=test jest __tests__/backend/api/enterpriseExport.test.js --coverage --verbose",
    "test:enterprise": "vitest run --config vitest.config.enterprise.ts",
    "test:enterprise:watch": "vitest --config vitest.config.enterprise.ts",
    "test:enterprise:ui": "vitest --config vitest.config.enterprise.ts --ui",
    "coverage:enterprise": "vitest run --config vitest.config.enterprise.ts --coverage",
    "test:e2e": "NODE_ENV=test jest __tests__/e2e/ --testTimeout=10000",
    "test:security": "jest --config=jest.config.simple.js --coverage --verbose",
    "start": "node server.js",
    "dev": "nodemon server.js",
    "voice-test": "node test-elevenlabs-real-key.js",
    "validate:microstep-0.1": "node scripts/validate-microstep-0.1.cjs",
    "test:analysis": "jest __tests__/backend/analysis/ --coverage --collectCoverageFrom='backend/analysis/**/*.cjs'",
    "test:unit:backend": "jest __tests__/backend/ --coverage",
    "test:coverage:check": "jest --coverage --coverageThreshold='{\"global\":{\"branches\":95,\"functions\":95,\"lines\":95,\"statements\":95}}'",
    "validate:all": "npm run test:coverage:check && npm run validate:microstep-0.1",
    "coverage:check": "nyc check-coverage --statements 95 --branches 95 --functions 95 --lines 95",
    "security:scan": "npm audit --audit-level=moderate",
    "validate:phase2": "npm run test:phase2 && npm run test:api:security && npm run test:performance:api",
    "test:legacy": "vitest run __tests_legacy__ legacy_tests tests/voice tests/infographic tests/ui --reporter=verbose --testTimeout=60000",
    "start:full": "node launch-prism-full-stack.js",
    "start:monitoring": "docker-compose -f docker-compose-monitoring.yml up -d",
    "stop:monitoring": "docker-compose -f docker-compose-monitoring.yml down",
    "test:voice": "vitest run --config vitest.config.voice.js",
    "test:voice:watch": "vitest --config vitest.config.voice.js",
    "test:voice:coverage": "vitest run --config vitest.config.voice.js --coverage",
    "test:voice:ui": "vitest --config vitest.config.voice.js --ui",
    "test:pdf": "vitest run --config vitest.config.pdf.js",
    "test:pdf:coverage": "vitest run --config vitest.config.pdf.js --coverage",
    "test:orchestrator": "vitest run --config vitest.config.orchestrator.js",
    "test:orchestrator:watch": "vitest --config vitest.config.orchestrator.js",
    "test:orchestrator:coverage": "vitest run --config vitest.config.orchestrator.js --coverage",
    "test:infographic": "vitest run --config vitest.config.infographic.js",
    "test:infographic:watch": "vitest --config vitest.config.infographic.js",
    "test:core:coverage": "vitest run --config vitest.config.core.js --coverage",
    "test:scenarios": "node tests/integration/final-scenarios-test.js",
    "test:excel": "vitest run --config vitest.config.excel.js",
    "test:excel:watch": "vitest --config vitest.config.excel.js",
    "test:excel:coverage": "vitest run --config vitest.config.excel.js --coverage",
    "test:properties": "vitest run __tests__/properties --reporter=verbose --testTimeout=60000",
    "test:fuzz": "vitest run __tests__/fuzz --reporter=verbose --testTimeout=30000",
    "test:providers": "vitest run __tests__/properties/providers.properties.test.ts __tests__/adversarial/providers.adversarial.test.ts --reporter=verbose --testTimeout=60000",
    "test:proof": "npm run test:properties && npm run test:fuzz",
    "test:proof:full": "npm run test:proof && npm run test:providers"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.26.0",
    "@apidevtools/swagger-parser": "^10.1.1",
    "@apollo/client": "^3.9.5",
    "@fal-ai/client": "^1.7.2",
    "@google/genai": "^1.0.0",
    "@supabase/supabase-js": "^2.49.4",
    "autocannon": "^8.0.0",
    "benchmark": "^2.1.4",
    "better-sqlite3": "^11.10.0",
    "chalk": "^5.4.1",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "exceljs": "^4.4.0",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.0",
    "express-slow-down": "^2.1.0",
    "helmet": "^8.1.0",
    "isomorphic-dompurify": "^2.25.0",
    "jest-canvas-mock": "^2.5.2",
    "jest-environment-jsdom": "^30.0.0-beta.3",
    "jest-junit": "^16.0.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "mathjs": "^15.1.0",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "natural": "^8.1.0",
    "node-fetch": "^3.3.2",
    "nyc": "^15.1.0",
    "openai": "^4.96.0",
    "pdfkit": "^0.17.1",
    "prom-client": "^14.2.0",
    "redis-mock": "^0.56.3",
    "simple-statistics": "^7.8.8",
    "socket.io": "^4.8.1",
    "three": "^0.176.0",
    "validator": "^13.15.15",
    "winston": "^3.11.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@apidevtools/swagger-parser": "^10.1.1",
    "@eslint/js": "^9.39.2",
    "@faker-js/faker": "^9.9.0",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^3.2.4",
    "autocannon": "^8.0.0",
    "benchmark": "^2.1.4",
    "cors": "^2.8.5",
    "dotenv-safe": "^9.1.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.0",
    "express-slow-down": "^2.1.0",
    "fast-check": "^4.4.0",
    "helmet": "^8.1.0",
    "husky": "^9.1.7",
    "isomorphic-dompurify": "^2.25.0",
    "jest-canvas-mock": "^2.5.2",
    "jest-environment-jsdom": "^30.0.0-beta.3",
    "jest-junit": "^16.0.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "lint-staged": "^15.5.2",
    "morgan": "^1.10.0",
    "nyc": "^15.1.0",
    "prettier": "^3.7.4",
    "redis-mock": "^0.56.3",
    "supertest": "^7.1.4",
    "validator": "^13.15.15",
    "vitest": "^3.2.4",
    "zod": "^4.1.13"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "keywords": [
    "ai",
    "prism"
  ]
}
