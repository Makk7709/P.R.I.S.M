{
  "name": "prism",
  "version": "2.0.0",
  "description": "PRISM v2 - Advanced AI Orchestration System",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "lint": "echo 'Linting passed - no linter configured'",
    "test:consensus": "vitest run --config vitest.config.consensus.mjs",
    "demo:consensus": "node demo-consensus-live.js",
    "scenarios:all": "node run-consensus-tests.js",
    "coverage:consensus": "vitest run --config vitest.config.consensus.mjs && (command -v open >/dev/null 2>&1 && open coverage/index.html || true)",
    "test:phase1": "NODE_ENV=test jest __tests__/backend/services/ --coverage --verbose",
    "test:phase2": "NODE_ENV=test npm run test:enterprise:all",
    "test:enterprise:all": "NODE_ENV=test jest __tests__/backend/api/enterpriseExport.test.js __tests__/backend/middleware/ --coverage --verbose",
    "test:enterprise:middleware": "NODE_ENV=test jest __tests__/backend/middleware/ --coverage --verbose",
    "test:enterprise:api": "NODE_ENV=test jest __tests__/backend/api/enterpriseExport.test.js --coverage --verbose",
    "test:enterprise": "vitest run --config vitest.config.enterprise.ts",
    "test:enterprise:watch": "vitest --config vitest.config.enterprise.ts",
    "test:enterprise:ui": "vitest --config vitest.config.enterprise.ts --ui",
    "coverage:enterprise": "vitest run --config vitest.config.enterprise.ts --coverage",
    "test:e2e": "NODE_ENV=test jest __tests__/e2e/ --testTimeout=10000",
    "test:security": "jest --config=jest.config.simple.js --coverage --verbose",
    "start": "node server.js",
    "dev": "nodemon server.js",
    "voice-test": "node test-elevenlabs-real-key.js",
    "validate:microstep-0.1": "node scripts/validate-microstep-0.1.cjs",
    "test:analysis": "jest __tests__/backend/analysis/ --coverage --collectCoverageFrom='backend/analysis/**/*.cjs'",
    "test:unit:backend": "jest __tests__/backend/ --coverage",
    "test:coverage:check": "jest --coverage --coverageThreshold='{\"global\":{\"branches\":95,\"functions\":95,\"lines\":95,\"statements\":95}}'",
    "validate:all": "npm run test:coverage:check && npm run validate:microstep-0.1",
    "coverage:check": "nyc check-coverage --statements 95 --branches 95 --functions 95 --lines 95",
    "security:scan": "npm audit --audit-level=moderate",
    "validate:phase2": "npm run test:phase2 && npm run test:api:security && npm run test:performance:api",
    "test:legacy": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config legacy_tests/jest.config.js",
    "start:full": "node launch-prism-full-stack.js",
    "start:monitoring": "docker-compose -f docker-compose-monitoring.yml up -d",
    "stop:monitoring": "docker-compose -f docker-compose-monitoring.yml down"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.26.0",
    "@apidevtools/swagger-parser": "^10.1.1",
    "@apollo/client": "^3.9.5",
    "@supabase/supabase-js": "^2.49.4",
    "autocannon": "^8.0.0",
    "benchmark": "^2.1.4",
    "better-sqlite3": "^11.10.0",
    "chalk": "^5.4.1",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.0",
    "express-slow-down": "^2.1.0",
    "helmet": "^8.1.0",
    "isomorphic-dompurify": "^2.25.0",
    "jest-canvas-mock": "^2.5.2",
    "jest-environment-jsdom": "^30.0.0-beta.3",
    "jest-junit": "^16.0.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "natural": "^8.0.1",
    "node-fetch": "^3.3.2",
    "nyc": "^15.1.0",
    "openai": "^4.96.0",
    "pdfkit": "^0.17.1",
    "prom-client": "^14.2.0",
    "redis-mock": "^0.56.3",
    "socket.io": "^4.8.1",
    "supertest": "^7.1.1",
    "three": "^0.176.0",
    "validator": "^13.15.15",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@apidevtools/swagger-parser": "^10.1.1",
    "@faker-js/faker": "^9.9.0",
    "@vitest/coverage-v8": "^3.2.4",
    "autocannon": "^8.0.0",
    "benchmark": "^2.1.4",
    "cors": "^2.8.5",
    "dotenv-safe": "^9.1.0",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.0",
    "express-slow-down": "^2.1.0",
    "helmet": "^8.1.0",
    "isomorphic-dompurify": "^2.25.0",
    "jest-canvas-mock": "^2.5.2",
    "jest-environment-jsdom": "^30.0.0-beta.3",
    "jest-junit": "^16.0.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "nyc": "^15.1.0",
    "redis-mock": "^0.56.3",
    "supertest": "^7.1.1",
    "validator": "^13.15.15",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "keywords": [
    "ai",
    "prism"
  ]
}
