# 🚀 PRISM TURBO MODE - Optimisations de Performance
# Copier ces variables dans votre .env principal

# ⚡ Activations Turbo
PRISM_TURBO_MODE=true
PRISM_SKIP_CONTEXT=true

# 🔧 Modèles rapides recommandés
OPENAI_MODEL=gpt-3.5-turbo
ANTHROPIC_MODEL=claude-3-haiku-20240307

# 📊 Pour retrouver <50ms de latence :
# 1. Activer PRISM_TURBO_MODE=true
# 2. Activer PRISM_SKIP_CONTEXT=true  
# 3. Utiliser gpt-3.5-turbo au lieu de gpt-4-turbo
# 4. Le cache LRU gérera les réponses répétées
# 5. Les réponses demo seront <10ms

# ⚠️ Note: En mode TURBO, les réponses sont plus rapides mais moins détaillées 