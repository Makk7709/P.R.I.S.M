# Use legacy peer dependency resolution so that `npm ci` accepts the
# transitive zod v3 vs zod v4 conflict between:
#   - openai@4.x (peerOptional zod@^3.23.8)
#   - root project (zod@^4)
#   - @modelcontextprotocol/sdk@1.x (zod@^3.25 || ^4.0)
# The conflict is on a peerOptional only; openai functions correctly
# without zod. Documented in PRISM_03_REPO_HYGIENE_CLEANUP_REPORT.md §5.
# To revisit: see PRISM_04_DEPENDENCY_REPRODUCIBILITY_FIX.
legacy-peer-deps=true
