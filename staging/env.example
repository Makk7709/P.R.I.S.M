# Staging Environment Configuration
# Copy this to .env and fill with your values

# Mode
PRISM_MODE=staging
PRISM_USE_REAL_PROVIDERS=false

# Provider API Keys (optional for staging - can use mocks)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
PERPLEXITY_API_KEY=
PERPLEXITY_BASE_URL=
PERPLEXITY_MODEL=llama-3.1-sonar-large-128k-online

# TrustContext Configuration
TRUSTCONTEXT_KEYS_DIR=./keys/approvers
TRUSTCONTEXT_KEYREGISTRY_PATH=./data/key-registry.json
TRUSTCONTEXT_APPROVAL_TIMEOUT_MS=1800000

# Metrics
METRICS_ENABLED=true
METRICS_OUTPUT_DIR=./staging/metrics

# Node
NODE_ENV=staging
PORT=3000
