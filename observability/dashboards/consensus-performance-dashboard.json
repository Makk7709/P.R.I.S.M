{
  "dashboard": {
    "id": null,
    "title": "PRISM Consensus Performance",
    "tags": ["prism", "consensus", "performance"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "Decision Latency (p50/p95)",
        "type": "stat",
        "targets": [
          {
            "expr": "histogram_quantile(0.5, prism_consensus_decision_latency_ms)",
            "legendFormat": "p50"
          },
          {
            "expr": "histogram_quantile(0.95, prism_consensus_decision_latency_ms)",
            "legendFormat": "p95"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ms",
            "thresholds": {
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 300},
                {"color": "red", "value": 500}
              ]
            }
          }
        }
      },
      {
        "id": 2,
        "title": "No Consensus Rate",
        "type": "stat",
        "targets": [
          {
            "expr": "rate(prism_consensus_no_consensus_total[5m])",
            "legendFormat": "No Consensus Rate"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "thresholds": {
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 0.1},
                {"color": "red", "value": 0.2}
              ]
            }
          }
        }
      },
      {
        "id": 3,
        "title": "Provider Timeout Total",
        "type": "graph",
        "targets": [
          {
            "expr": "sum by (provider) (prism_consensus_provider_timeout_total)",
            "legendFormat": "{{provider}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "thresholds": {
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 5},
                {"color": "red", "value": 10}
              ]
            }
          }
        }
      },
      {
        "id": 4,
        "title": "Quorum Success Rate",
        "type": "stat",
        "targets": [
          {
            "expr": "rate(prism_consensus_quorum_success_total[5m])",
            "legendFormat": "Quorum Success"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "thresholds": {
              "steps": [
                {"color": "red", "value": null},
                {"color": "yellow", "value": 0.8},
                {"color": "green", "value": 0.9}
              ]
            }
          }
        }
      }
    ],
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "refresh": "30s"
  }
}
