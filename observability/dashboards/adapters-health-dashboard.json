{
  "dashboard": {
    "id": null,
    "title": "PRISM Adapters Health",
    "tags": ["prism", "adapters", "health"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "OpenAI Adapter Health",
        "type": "row",
        "panels": [
          {
            "id": 11,
            "title": "Latency",
            "type": "stat",
            "targets": [
              {
                "expr": "prism_adapter_latency_ms{adapter=\"openai\"}",
                "legendFormat": "OpenAI Latency"
              }
            ],
            "fieldConfig": {
              "defaults": {
                "unit": "ms",
                "thresholds": {
                  "steps": [
                    {"color": "green", "value": null},
                    {"color": "yellow", "value": 250},
                    {"color": "red", "value": 300}
                  ]
                }
              }
            }
          },
          {
            "id": 12,
            "title": "Error Rate",
            "type": "stat",
            "targets": [
              {
                "expr": "rate(prism_adapter_errors_total{adapter=\"openai\"}[5m])",
                "legendFormat": "OpenAI Errors"
              }
            ],
            "fieldConfig": {
              "defaults": {
                "unit": "percent",
                "thresholds": {
                  "steps": [
                    {"color": "green", "value": null},
                    {"color": "yellow", "value": 0.05},
                    {"color": "red", "value": 0.1}
                  ]
                }
              }
            }
          },
          {
            "id": 13,
            "title": "Circuit Breaker",
            "type": "stat",
            "targets": [
              {
                "expr": "prism_adapter_circuit_breaker_open{adapter=\"openai\"}",
                "legendFormat": "Circuit Open"
              }
            ],
            "fieldConfig": {
              "defaults": {
                "unit": "short",
                "thresholds": {
                  "steps": [
                    {"color": "green", "value": 0},
                    {"color": "red", "value": 1}
                  ]
                }
              }
            }
          }
        ]
